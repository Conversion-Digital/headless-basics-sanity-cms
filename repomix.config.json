{
    "output": {
        "filePath": "repomix-output.xml",
        "style": "xml",
        "headerText": "Custom header information for the packed file.",
        "removeComments": true,
        "removeEmptyLines": true,
        "showLineNumbers": false,
        "copyToClipboard": false,
        "topFilesLength": 5,
        "includeEmptyDirectories": false,
        "instructionFilePath": "repomix-base.prompt"
    },
    "include": [
        "./grid",
        "./schemaTypes",
        "ChangeLog.md",
        "LICENSE",
        "README.md",
        "package.json",
        "tsconfig.json",
        "global.d.ts",
        "pageTreeConfig.ts",
        "sanity-next/packages/sanity/src/core/form/inputs/arrays"
    ],
    "ignore": {
        "useGitignore": true,
        "useDefaultPatterns": true,
        "customPatterns": [
            "repomix.config.json",
            "repomix-base.prompt",
            "repomix-output.xml",
            "./**/.github",
            "./**/.vscode",
            "./**/.gitignore",
            "./**/*.git",
            "./**/*.yml",
            "./**/*.storybook",
            "./**/*.idea",
            "./**/public",
            "./**/node_modules",
            "packages/headless-basics-starter-site/dist",
            "./**/repomix.config.json",
            ".sanity",
            "packages/headless-basics-starter-site/.prettierrc.json",
            "./**/tsconfig.tsbuildinfo",
            "./sanity-plugin-hotspot-array-main",
            "./cc"
        ]
    },
    "security": {
        "enableSecurityCheck": true
    }
}